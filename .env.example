# Collective Intelligence Terminal — Environment Variables
# ALL OPTIONAL — core functionality works without any keys
# Enter these in the ⚙ MARKET modal or set as Vercel environment variables

# ─── MARKET DATA ────────────────────────────────────────────────────
# Alpha Vantage: server-verified RSI + moving averages
# Free at: https://alphavantage.co/support
ALPHA_VANTAGE_KEY=

# Polygon.io: real NYSE breadth data (% stocks above each MA)
# Free starter plan at: https://polygon.io
POLYGON_KEY=

# FRED: Federal Reserve economic data (Fed rate, CPI, 10Y yield)
# Free at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_KEY=

# Finnhub: AAPL, MSFT, NVDA live prices for deliberation context
# Free at: https://finnhub.io
FINNHUB_KEY=

# NASA: Near-Earth Object (NEO) database for astrophysics domain
# Free at: https://api.nasa.gov — DEMO_KEY works but is rate-limited
NASA_KEY=DEMO_KEY

# ─── NEWS & WORLD INTELLIGENCE ───────────────────────────────────────
# GNews: 100 headlines/day free — political, entertainment, crime, world
# Free at: https://gnews.io
GNEWS_KEY=

# ─── OPTIONS FLOW ────────────────────────────────────────────────────
# Unusual Whales: full institutional options flow + dark pool prints
# Free public endpoints active without key
# Enhanced tier at: https://unusualwhales.com
UNUSUAL_WHALES_KEY=

# ─── PAPER TRADING ───────────────────────────────────────────────────
# Alpaca: stock/ETF/crypto paper trading — no deposit required
# Free paper account at: https://alpaca.markets
# Use PAPER trading keys (paper-api.alpaca.markets endpoint)
ALPACA_KEY=
ALPACA_SECRET=

# ─── NOTES ───────────────────────────────────────────────────────────
# Anthropic API key: entered in the bottom bar of the terminal UI
# Polymarket trading: uses MetaMask wallet — no API key needed
# Yahoo Finance, CoinGecko, GDELT, Reddit, EONET, ProPublica,
# Treasury, Exchange Rates, Open-Meteo, USGS, NWS, GBIF, ESPN,
# ClinicalTrials.gov, Wikipedia, OpenSanctions, SpaceX Launch Library:
# ALL FREE — NO KEY REQUIRED — Active automatically on load
